# Coffee POS System - Environment Configuration
# Copy this file to .env and update with your values

# ── Server Configuration ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development  # Options: development, production, test

# ── Database Configuration ────────────────────────────────────────────────────
# SQLite database file path (relative to project root)
DATABASE_PATH=./data/coffee_pos.db

# ── Security ──────────────────────────────────────────────────────────────────
# CRITICAL: Generate a strong secret key for JWT tokens
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be changed in production!
JWT_SECRET=your-secret-key-change-in-production
SESSION_SECRET=your-secret-key-change-in-production

# JWT token expiration time
# Options: '1h', '24h', '7d', '30d', etc.
JWT_EXPIRES_IN=24h

# ── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Leave empty to allow all origins (development only)
# Production example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Time window for rate limiting (in milliseconds)
# Default: 15 minutes (900000ms)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per IP
# Default: 100 requests
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: error, warn, info, debug
# In production, logs are written to logs/access.log
LOG_LEVEL=info

# ── SSL/HTTPS (optional - for direct Node.js SSL) ────────────────────────────
# Note: Recommended to use a reverse proxy (nginx) for SSL in production
# SSL_ENABLED=false
# SSL_KEY_PATH=./ssl/private.key
# SSL_CERT_PATH=./ssl/certificate.crt

# ── Database Backup (optional) ────────────────────────────────────────────────
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_HOURS=24
# BACKUP_DIR=./backups
