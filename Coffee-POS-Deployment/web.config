<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Enable WebSocket support -->
    <webSocket enabled="true" />
    
    <!-- IIS Node configuration -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>
    
    <!-- Rewrite rules to redirect all traffic to server.js -->
    <rewrite>
      <rules>
        <!-- Don't intercept requests for static files -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="^(/styles\.css|/reset\.html|/.*\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map))$" />
          <action type="None" />
        </rule>
        
        <!-- Redirect all other requests to server.js -->
        <rule name="DynamicContent" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- Security settings -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>
    
    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="server.js" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
