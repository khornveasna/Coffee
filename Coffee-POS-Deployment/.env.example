# Coffee POS System - Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=3002
NODE_ENV=production

# Database Configuration
# Leave empty for default SQLite database
# DATABASE_URL=sqlite:///coffee_pos.db

# Security
# Generate a strong secret key for session management
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-secret-key-change-in-production

# CORS Configuration (comma-separated origins)
# Leave empty to allow all origins (not recommended for production)
# CORS_ORIGINS=http://localhost:3002,https://yourdomain.com

# Logging
# Options: error, warn, info, debug
LOG_LEVEL=info

# Rate Limiting
# Maximum requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SSL/HTTPS (optional - for direct Node.js SSL)
# SSL_ENABLED=false
# SSL_KEY_PATH=./ssl/private.key
# SSL_CERT_PATH=./ssl/certificate.crt

# Database Backup (optional)
# BACKUP_ENABLED=true
# BACKUP_INTERVAL_HOURS=24
# BACKUP_DIR=./backups
